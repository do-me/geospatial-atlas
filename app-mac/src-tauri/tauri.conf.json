{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Geospatial Atlas",
  "version": "0.20.0",
  "identifier": "io.github.do-me.geospatial-atlas",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Geospatial Atlas",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "shortDescription": "Native WebGPU-compatible MacOS viewer for geospatial & embedding data",
    "longDescription": "Native WebGPU-compatible MacOS viewer for geospatial & embedding data",
    "copyright": "MIT License",
    "category": "DeveloperTool",
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "frameworks": []
    },
    "externalBin": ["binaries/geospatial-atlas-sidecar"],
    "resources": {
      "../resources/sidecar/": "sidecar/"
    }
  },
  "plugins": {}
}
